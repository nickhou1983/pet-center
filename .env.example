# PostgreSQL (pgvector) connection string.
# Used by Prisma and the application. Credentials match docker-compose.yml.
DATABASE_URL="postgresql://petcenter:petcenter@localhost:5432/petcenter?schema=public"

# transformers.js (CLIP) model cache directory.
# On first run the CLIP model (Xenova/clip-vit-base-patch32, ~300MB) is
# downloaded from the Hugging Face Hub and cached here; later runs load from
# disk. Path is relative to the project root and is git-ignored. Optional —
# defaults to "./.cache" when unset (see lib/clip.ts).
TRANSFORMERS_CACHE="./.cache"
