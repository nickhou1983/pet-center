# PostgreSQL (pgvector) connection string.
# Used by Prisma and the application. Credentials match docker-compose.yml.
DATABASE_URL="postgresql://petcenter:petcenter@localhost:5432/petcenter?schema=public"

# Image upload service (M4). Optional overrides for POST /api/upload.
# Maximum size per uploaded file, in bytes (default 5 MB).
UPLOAD_MAX_FILE_SIZE_BYTES="5242880"
# Maximum number of files accepted per request (default 10).
UPLOAD_MAX_FILES="10"
